{
  "name": "ciclomapa",
  "version": "3.0.0",
  "private": true,
  "homepage": "https://ciclomapa.app",
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "dependencies": {
    "@craco/craco": "^7.1.0",
    "@mapbox/mapbox-gl-geocoder": "^5.0.3",
    "@mapbox/mapbox-sdk": "^0.16.2",
    "@turf/bbox": "^7.2.0",
    "@turf/circle": "^7.2.0",
    "@turf/distance": "^7.2.0",
    "@turf/length": "^7.2.0",
    "@turf/line-overlap": "^7.2.0",
    "antd": "^4.14.0",
    "aws-sdk": "^2.1692.0",
    "craco-less": "^3.0.1",
    "file-saver": "^2.0.5",
    "firebase": "^8.3.1",
    "gh-pages": "^6.3.0",
    "idb-keyval": "^6.2.1",
    "jquery": "^3.6.0",
    "lodash.debounce": "^4.0.8",
    "mapbox-gl": "^3.19.1",
    "mapbox-pmtiles": "^1.0.54",
    "osmtogeojson": "^3.0.0-beta.4",
    "pako": "^2.0.3",
    "prop-types": "^15.8.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-icons": "^5.4.0",
    "react-router-dom": "^6.4.0",
    "react-scripts": "^5.0.1",
    "recharts": "^2.0.8",
    "skmeans": "^0.11.3",
    "zipson": "^0.2.12"
  },
  "scripts": {
    "start": "craco start",
    "build": "craco build",
    "test": "craco test",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "lint": "eslint src/",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --write \"{src,scripts,docs}/**/*.{js,jsx,ts,tsx,json,css,less,md}\"",
    "format:check": "prettier --check \"{src,scripts,docs}/**/*.{js,jsx,ts,tsx,json,css,less,md}\"",
    "eject": "react-scripts eject",
    "predeploy": "yarn run build",
    "deploy": "gh-pages -d build",
    "dev:vercel": "vercel dev",
    "overpass": "node scripts/overpass-to-geojson.js",
    "generate-pwa-icons": "node scripts/generate-pwa-icons.js",
    "prepare": "husky || true"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-typescript": "^7.27.1",
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-loader": "^10.0.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "jest-axe": "^10.0.0",
    "lint-staged": "^15.2.10",
    "prettier": "^3.4.2",
    "sharp": "^0.34.5",
    "to-ico": "^1.1.5",
    "typescript": "^4.9.5",
    "vercel": "^48.0.1"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{json,css,less,md}": [
      "prettier --write"
    ]
  }
}
