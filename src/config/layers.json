    "type": "poi",
    "icon": "poi-bikeparking",
    "zoomThreshold": 16.5,
    "style": {
      "textColor": "#2F904A"
    }
  },
  {
    "name": "Ciclovia",
    "displayName": "Ciclovias",
    "description": "Vias protegidas e exclusivas para bicicletas. Ciclovias são separadas fisicamente por meio-fio, muretas ou outros tipos de segregação fixa que impedem a circulação de veículos.",
    "protectionLevel": "Alta",
    "filters": [
      ["highway", "cycleway"],
      ["cycleway", "track"],
      ["cycleway:left", "track"],
      ["cycleway:right", "track"],
      ["cycleway", "opposite_track"],
      ["cycleway:left", "opposite_track"],
      ["cycleway:right", "opposite_track"]
    ],
    "zoomThreshold": 15,
    "style": {
      "lineColor": "#386641",
      "lineColorDark": "#B9FAB7",
      "textColor": "#FFFFFF",
      "textColorDark": "#000000",
      "lineWidth": 8
    }
  },
  {
    "name": "Calçada compartilhada",
    "displayName": "Calçadas compartilhadas",
    "shortName": "Calçadas",
    "description": "Calçadas com sinalização para circulação compartilhada de bicicletas. Lembre-se que pedestres possuem a prioridade.",
    "protectionLevel": "Alta",
    "filters": [
      [
        ["highway", "footway"],
        ["bicycle", "designated"]
      ],
      [
        ["highway", "pedestrian"],
        ["bicycle", "designated"]
      ],
      [
        ["highway", "pedestrian"],
        ["bicycle", "yes"]
      ],
      ["cycleway", "sidepath"],
      ["cycleway:left", "sidepath"],
      ["cycleway:right", "sidepath"]
    ],
    "style": {
      "lineColor": "#386641",
      "lineColorDark": "#B9FAB7",
      "textColor": "#FFFFFF",
      "textColorDark": "#000000",
      "lineWidth": 8,
      "lineStyle": "dashed"
    }
  },
  {
    "name": "Ciclofaixa",
    "displayName": "Ciclofaixas",
    "description": "Vias exclusivas para bicicletas mas sem segregação física, apenas demarcada por faixa pintada no chão ou outra sinalização",
    "protectionLevel": "Média",
    "filters": [
      ["cycleway", "lane"],
      ["cycleway:left", "lane"],
      ["cycleway:right", "lane"],
      ["cycleway:both", "lane"],
      ["cycleway", "opposite_lane"],
      ["cycleway:right", "opposite_lane"],
      ["cycleway:left", "opposite_lane"]
    ],
    "style": {
      "lineColor": "#A7C957",
      "lineColorDark": "#486B2E",
      "textColor": "#000000",
      "textColorDark": "#FFFFFF",
      "lineWidth": 8
    }
  },
  {
    "name": "Ciclorrota",
